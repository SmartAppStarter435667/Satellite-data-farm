# ================================================================
# SATELLITE PRO - 環境変数テンプレート
# このファイルをコピーして .env.local を作成してください
#
# cp .env.example apps/globe-gl/.env.local
#
# ⚠️  .env.local は .gitignore に追加して絶対にコミットしない！
# ================================================================

# =============================================
# フロントエンド用（VITE_ プレフィックス必須）
# apps/globe-gl/.env.local に配置
# =============================================

# Supabase（Project Settings > API）
VITE_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# バックエンドAPI（Render.comのデプロイURL）
VITE_API_BASE_URL=https://satellite-pro-api.onrender.com


# =============================================
# バックエンド用（Render.com Environment Variables）
# backend/.env または Render ダッシュボードに設定
# =============================================

# Google Earth Engine
EE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"..."}
EE_SERVICE_ACCOUNT_EMAIL=your-sa@your-project.iam.gserviceaccount.com

# Google AI Studio（Gemini）
# https://aistudio.google.com/app/apikey
GEMINI_API_KEY=AIzaSy...

# Supabase（サーバーサイド：SERVICE_KEY は公開禁止）
SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
SUPABASE_SERVICE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# MongoDB Atlas（Connect > Drivers > Python 3.12+）
# mongodb+srv://username:password@cluster0.xxxxx.mongodb.net/satellite_pro
MONGODB_URI=mongodb+srv://satellitepro:your-password@cluster0.xxxxx.mongodb.net/satellite_pro?retryWrites=true&w=majority

# Neo4j AuraDB（Console > Connect）
NEO4J_URI=neo4j+s://xxxxxxxx.databases.neo4j.io
NEO4J_USER=neo4j
NEO4J_PASS=your-generated-password

# CORS（カンマ区切りで複数指定可）
ALLOWED_ORIGINS=https://your-project.pages.dev,http://localhost:5173


# =============================================
# GitHub Secrets（CI/CD用）
# Settings > Secrets and variables > Actions
# =============================================

# Cloudflare Pages デプロイ
CLOUDFLARE_API_TOKEN=your-api-token
CLOUDFLARE_ACCOUNT_ID=your-account-id
CLOUDFLARE_PROJECT_NAME=satellite-pro

# Render（ヘルスチェック用）
RENDER_API_URL=https://satellite-pro-api.onrender.com

# 上記の全変数も GitHub Secrets に追加が必要
# （data_processor_v2.py が GitHub Actions で実行されるため）
